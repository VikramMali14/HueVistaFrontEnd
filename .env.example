# Base URL of the HueVista backend (Spring Boot)
# In development this is your local backend; in production point at the public API.
# The browser never talks here directly: all authenticated requests go through
# the same-origin BFF route (/bff/*) which attaches the access token server-side.
NEXT_PUBLIC_API_ORIGIN=http://localhost:8080

# Used by Next.js server actions and the BFF route when calling the backend.
# Usually identical to NEXT_PUBLIC_API_ORIGIN unless you proxy internally (e.g.
# a private cluster-local URL for server-to-server calls).
API_INTERNAL_ORIGIN=http://localhost:8080

# Secret used to sign session cookies (32+ random chars).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string

# AWS region the backend's S3 bucket lives in. Used to allow
# `https://*.s3.<region>.amazonaws.com` in the CSP img-src so the browser can
# load presigned image URLs returned by the backend. Must match the backend's
# `app.s3.region`. Defaults to `ap-south-1`.
S3_REGION=ap-south-1

# Optional: comma-separated list of extra image hosts allowed by the CSP img-src
# (e.g. a CDN, or a bucket in a non-default region). The backend host and the
# S3 wildcard for `S3_REGION` are already allowed.
IMAGE_REMOTE_HOSTS=

# Dev-only auth bypass — set to 1 to skip the real login during local UI work.
# Ignored in production builds. Backend calls (upload, project flow) will fail
# under bypass; only flows that read from local sample data work without a backend.
# DEV_BYPASS_AUTH=1
