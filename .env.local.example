# Copy this file to `.env.local` (Next.js loads it automatically) and adjust if needed.

# Base URL of the HueVista backend (Spring Boot). The browser never calls this
# directly — authenticated requests go through the same-origin BFF (/bff/*).
NEXT_PUBLIC_API_ORIGIN=http://localhost:8080

# Server-to-server origin used by Next server actions + the BFF route.
API_INTERNAL_ORIGIN=http://localhost:8080

# Optional: skip real login during pure UI work (DEV ONLY, ignored in prod builds).
# Backend calls (upload, project flow) will fail under bypass; only flows that read
# from local sample data work without a running, authenticated backend.
# DEV_BYPASS_AUTH=1
